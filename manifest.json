{
  "manifest_version": 3,
  "name": "FB Post Story Copier",
  "version": "1.0",
  "description": "Copy Facebook post text with one click",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html"
  },
  "host_permissions": [
    "https://www.facebook.com/*"
  ]
}
